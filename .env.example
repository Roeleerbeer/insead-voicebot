# Production env file shape. Copy to /etc/insead-voicebot/prod.env on the VPS
# (mode 600, root-owned), fill in the real values, and reference it via
# `--env-file /etc/insead-voicebot/prod.env` on the docker compose command.
# This file lives at the REPO ROOT and is committed; the real prod.env is NOT.

# ---- LiveKit (self-hosted) ----
# Generate fresh keys for production. NEVER use the dev placeholders here.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Public WSS URL the browser connects to (via Caddy). Match the Caddyfile.
PUBLIC_LIVEKIT_URL=wss://livekit.insead-voicebot.roelconijn.nl

# ---- Voice pipeline ----
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ---- Cost / abuse caps (defaults match compose.prod.yml) ----
MAX_MONTHLY_COST_USD=20
MAX_DAILY_COST_USD=5
MAX_SESSION_MINUTES=5
MAX_IP_MINUTES_PER_HOUR=8
MAX_CONCURRENT_SESSIONS=5

# ---- Admin ----
# Long random string. Used by the secret kill-switch URL:
#   https://insead-voicebot.roelconijn.nl/api/admin?key=<ADMIN_SECRET>&action=pause
ADMIN_SECRET=
