# Public — exposed to the browser.
# Local dev (docker-compose.dev.yml) defaults below. Prod will be wss://...
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# Server-only — used by /api/token to mint access tokens.
# `--dev` mode in livekit-server uses these built-in credentials.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
